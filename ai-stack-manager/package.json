{
  "name": "descomplicai",
  "displayName": "DescomplicAI",
  "description": "🧠 Simplifique sua infraestrutura de AI Agents — instale, visualize e gerencie redes de Agents, Skills, MCPs e Bundles com um clique.",
  "version": "0.1.0",
  "publisher": "itau-engineering",
  "icon": "media/icons/sidebar-icon.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "agents",
    "skills",
    "mcp",
    "copilot",
    "infrastructure",
    "package-manager",
    "itau",
    "descomplicai"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dai-sidebar",
          "title": "DescomplicAI",
          "icon": "media/icons/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "dai-sidebar": [
        {
          "id": "dai-catalog",
          "name": "Catálogo",
          "type": "webview"
        },
        {
          "id": "dai-installed",
          "name": "Instalados",
          "type": "webview"
        },
        {
          "id": "dai-health",
          "name": "Health Check",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "dai.install",
        "title": "DescomplicAI: Instalar Pacote",
        "icon": "$(add)"
      },
      {
        "command": "dai.uninstall",
        "title": "DescomplicAI: Desinstalar Pacote",
        "icon": "$(trash)"
      },
      {
        "command": "dai.healthCheck",
        "title": "DescomplicAI: Executar Health Check",
        "icon": "$(heart)"
      },
      {
        "command": "dai.scaffold",
        "title": "DescomplicAI: Criar Novo Pacote",
        "icon": "$(file-add)"
      },
      {
        "command": "dai.refresh",
        "title": "DescomplicAI: Atualizar Visualizações",
        "icon": "$(refresh)"
      },
      {
        "command": "dai.installBundle",
        "title": "DescomplicAI: Instalar Bundle",
        "icon": "$(package)"
      },
      {
        "command": "dai.openWorkflow",
        "title": "DescomplicAI: Abrir Visualizador de Workflow",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "dai.openInsights",
        "title": "DescomplicAI: Abrir Insights Engine",
        "icon": "$(graph)"
      },
      {
        "command": "dai.configureAgent",
        "title": "DescomplicAI: Configurar Agente",
        "icon": "$(gear)"
      },
      {
        "command": "dai.publishPackage",
        "title": "DescomplicAI: Contribuir / Publicar",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "dai.importCustomMcp",
        "title": "DescomplicAI: Importar MCP Customizado",
        "icon": "$(plug)"
      }
    ],
    "chatParticipants": [
      {
        "id": "dai.stack",
        "name": "stack",
        "fullName": "DescomplicAI",
        "description": "Gerencie sua infraestrutura de AI agents — instale pacotes, verifique a saúde, explore workflows.",
        "isSticky": false,
        "commands": [
          {
            "name": "recommend",
            "description": "Analisa seu projeto e recomenda agents e skills"
          },
          {
            "name": "explain",
            "description": "Explica um agent ou pacote específico em detalhes"
          },
          {
            "name": "workflow",
            "description": "Mostra o pipeline de workflow dos agents"
          },
          {
            "name": "health",
            "description": "Executa um health check na sua infraestrutura de AI"
          },
          {
            "name": "install",
            "description": "Instala um pacote ou bundle"
          }
        ]
      }
    ],
    "configuration": {
      "title": "DescomplicAI",
      "properties": {
        "descomplicai.registryUrl": {
          "type": "string",
          "default": "https://github.com/guilherme-xmatch/DescomplicAI.git",
          "description": "URL do catálogo oficial manifest-driven (repositório Git ou index.json)."
        },
        "descomplicai.allowUnsafeRegistryUrls": {
          "type": "boolean",
          "default": false,
          "description": "Permite usar catálogos remotos fora da lista confiável. Ative apenas para desenvolvimento ou quando confiar explicitamente na origem."
        },
        "descomplicai.autoHealthCheck": {
          "type": "boolean",
          "default": true,
          "description": "Executar automaticamente o health check ao abrir um workspace."
        },
        "descomplicai.showWelcome": {
          "type": "boolean",
          "default": true,
          "description": "Mostrar mensagem de boas-vindas na primeira ativação."
        },
        "descomplicai.llmProvider": {
          "type": "string",
          "enum": [
            "Azure OpenAI",
            "Anthropic Claude",
            "Local Llama 3"
          ],
          "default": "Azure OpenAI",
          "description": "Provedor padrão de LLM para os agentes."
        },
        "descomplicai.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Temperatura global para os agentes ZM1 (0.0 a 1.0)."
        },
        "descomplicai.autoResolveDependencies": {
          "type": "boolean",
          "default": true,
          "description": "Sugerir automaticamente a instalação de dependências ao instalar uma rede de agents."
        },
        "descomplicai.metrics.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Opt-in para registrar eventos de instalação via GitHub e alimentar estatísticas públicas do catálogo."
        },
        "descomplicai.metrics.collectorOwner": {
          "type": "string",
          "default": "guilherme-xmatch",
          "description": "Owner do repositório GitHub que receberá eventos públicos de instalação."
        },
        "descomplicai.metrics.collectorRepo": {
          "type": "string",
          "default": "DescomplicAI",
          "description": "Repositório GitHub usado para coletar eventos de instalação agregados."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run --coverage",
    "test:unit": "vitest run test/domain test/infrastructure",
    "test:integration": "vitest run test/extension",
    "check": "npm run compile && npm run lint && npm run test",
    "check:github-prereqs": "powershell -ExecutionPolicy Bypass -File ./scripts/check-github-prereqs.ps1",
    "apply:branch-protection": "powershell -ExecutionPolicy Bypass -File ./scripts/apply-branch-protection.ps1",
    "clean": "rimraf out coverage vitest.config.js vitest.config.js.map vitest.config.d.ts vitest.config.d.ts.map"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "globals": "^15.15.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  },
  "dependencies": {
    "adm-zip": "^0.5.17"
  }
}
