{
  "id": "mcp-github",
  "name": "github-mcp",
  "displayName": "GitHub MCP",
  "description": "Integração MCP para GitHub.",
  "type": "mcp",
  "version": "1.0.0",
  "tags": ["mcp", "github"],
  "author": "DescomplicAI Community",
  "install": {
    "strategy": "mcp-merge",
    "targets": [
      {
        "source": "mcp.json",
        "target": ".vscode/mcp.json",
        "mergeStrategy": "merge-mcp-servers"
      }
    ]
  },
  "source": {
    "official": true,
    "packagePath": "mcps/github"
  },
  "ui": {
    "longDescription": "Servidor MCP do GitHub.",
    "highlights": ["Pull requests", "Issues"],
    "installNotes": ["Mescla com .vscode/mcp.json"],
    "badges": ["Official"],
    "maturity": "stable"
  }
}